rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        myProfile().role == 'admin';
    }

    // Employee record linked to the signed-in user (matched by email).
    function myEmployeeDoc() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid));
    }

    // -------------------------------------------------------------------
    // Users directory (roles, profile info)
    // -------------------------------------------------------------------
    match /users/{uid} {
      allow read: if isSignedIn();
      // Users may create/update their own profile (first login upsert),
      // admins may update anyone (e.g. to change roles).
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Only admins can delete a user from the directory, and never a
      // profile whose email is a fixed admin (enforced in-app too).
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------
    // Core HR data — read: any signed-in user, write: admins only.
    // Adjust per-collection if employees need to self-service specific
    // actions (e.g. submitting their own leave/expense requests).
    // -------------------------------------------------------------------
    match /employees/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /attendance/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /leave_requests/{docId} {
      allow read: if isSignedIn();
      // Employees can create/update their own leave requests; admins can
      // manage all of them (e.g. approve/reject).
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /leave_balances/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /payslips/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /payroll_runs/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /jobs/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /candidates/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /onboarding/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /goals/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /performance_reviews/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /expenses/{docId} {
      allow read: if isSignedIn();
      // Employees can submit/edit their own expense claims; admins manage all.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /assets/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /helpdesk_tickets/{docId} {
      allow read: if isSignedIn();
      // Employees can raise/update their own tickets; admins manage all.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.raisedById == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /regularizations/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------
    // Deny everything else by default.
    // -------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
